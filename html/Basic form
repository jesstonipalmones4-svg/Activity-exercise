    <?php
    // 2. PHP logic to check and display user input
    if (isset($_GET['name'])) {
        // htmlspecialchars prevents security issues like XSS
        $name = htmlspecialchars($_GET['name']); 
        
        if (!empty($name)) {
            echo "<h3>Hello, " . $name . "!</h3>";
        } else {
            echo "<h3>Please enter a name.</h3>";
        }
    }
