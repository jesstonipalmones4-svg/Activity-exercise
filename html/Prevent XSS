    <?php
    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        
        // 1. VULNERABLE DISPLAY (Do not use in production!)
        // If a user types a script, the browser will execute it.
        echo "<h3>Vulnerable Output (Raw Data):</h3>";
        echo "<p>" . $_POST['comment'] . "</p>";
        
        echo "<hr>";

        // 2. SECURE DISPLAY (Using htmlspecialchars)
        // This converts characters like < and > into safe HTML entities (&lt; and &gt;)
        $secureInput = htmlspecialchars($_POST['comment'], ENT_QUOTES, 'UTF-8');
        
        echo "<h3>Secure Output (Sanitized Data):</h3>";
        echo "<p>" . $secureInput . "</p>";
    }
    ?>

