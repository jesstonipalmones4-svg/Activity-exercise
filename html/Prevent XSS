<body>

    <!-- Basic submission form -->
    <form method="post" action="">
        <label for="userinput">Enter Comment / Script:</label><br>
        <input type="text" id="userinput" name="comment" style="width: 300px;" required>
        <input type="submit" value="Submit">
    </form>

